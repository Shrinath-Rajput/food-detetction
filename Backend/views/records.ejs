<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Records - Food Freshness Classification</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    /* ==================== NAVBAR STYLING ==================== */
    .navbar-professional {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
      padding: 1rem 0;
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 1000;
    }

    .navbar-professional .navbar-brand {
      font-size: 1.5rem;
      font-weight: bold;
      color: white !important;
      margin-right: 3rem;
    }

    .navbar-professional .nav-link {
      color: rgba(255, 255, 255, 0.85) !important;
      font-weight: 500;
      margin: 0 10px;
      padding: 8px 16px !important;
      border-radius: 20px;
      transition: all 0.3s ease;
      font-size: 0.95rem;
    }

    .navbar-professional .nav-link:hover {
      background: rgba(255, 255, 255, 0.2);
      color: white !important;
    }

    .navbar-professional .nav-link.active {
      background: rgba(255, 255, 255, 0.3);
      color: white !important;
      border-bottom: 2px solid white;
    }

    .navbar-professional .navbar-toggler {
      border-color: rgba(255, 255, 255, 0.3);
    }

    .navbar-professional .navbar-toggler-icon {
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255,255,255,0.75%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
    }

    .navbar-nav {
      margin-left: auto;
    }

    /* ==================== PAGE STYLING ==================== */
    body {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 100px 20px 30px 20px;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: white;
    }

    .container-main {
      max-width: 1200px;
      margin: 0 auto;
    }

    .page-header {
      text-align: center;
      margin-bottom: 30px;
      animation: slideDown 0.6s ease;
    }

    .page-header h1 {
      font-size: 2.5rem;
      font-weight: bold;
      margin-bottom: 10px;
    }

    .page-header p {
      font-size: 1.1rem;
      opacity: 0.95;
    }

    .filter-section {
      background: rgba(255, 255, 255, 0.1);
      padding: 20px;
      border-radius: 15px;
      margin-bottom: 30px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      animation: slideUp 0.6s ease 0.1s both;
    }

    .filter-btn {
      padding: 10px 20px;
      border-radius: 20px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      background: transparent;
      color: white;
      cursor: pointer;
      transition: all 0.3s ease;
      font-weight: 600;
    }

    .filter-btn:hover,
    .filter-btn.active {
      background: rgba(255, 255, 255, 0.3);
      border-color: white;
    }

    /* Records Grid */
    .records-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      animation: slideUp 0.6s ease 0.2s both;
    }

    .record-card {
      background: white;
      color: #333;
      border-radius: 15px;
      padding: 20px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .record-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    }

    .record-id {
      font-size: 0.9rem;
      color: #999;
      font-weight: 600;
    }

    .record-product {
      font-size: 1.3rem;
      font-weight: bold;
      color: #333;
    }

    .record-class {
      font-size: 0.95rem;
      color: #666;
      background: #f5f5f5;
      padding: 8px 12px;
      border-radius: 8px;
      display: inline-block;
    }

    .record-status {
      font-weight: 600;
      padding: 8px 12px;
      border-radius: 8px;
      text-align: center;
      font-size: 0.9rem;
    }

    .status-fresh {
      background: #d4edda;
      color: #155724;
    }

    .status-rotten {
      background: #f8d7da;
      color: #721c24;
    }

    .record-confidence {
      font-size: 0.9rem;
      color: #666;
    }

    .confidence-bar {
      width: 100%;
      height: 20px;
      background: #e0e0e0;
      border-radius: 10px;
      overflow: hidden;
      margin-top: 5px;
    }

    .confidence-fill {
      height: 100%;
      background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
      width: var(--width, 0%);
      transition: width 0.8s ease;
    }

    .record-date {
      font-size: 0.85rem;
      color: #999;
      border-top: 1px solid #eee;
      padding-top: 12px;
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 15px;
    }

    .empty-state-icon {
      font-size: 3rem;
      margin-bottom: 20px;
      opacity: 0.7;
    }

    .empty-state h3 {
      font-size: 1.5rem;
      margin-bottom: 10px;
    }

    .btn-predict {
      background: white;
      color: #667eea;
      padding: 10px 25px;
      border-radius: 20px;
      text-decoration: none;
      display: inline-block;
      margin-top: 20px;
      font-weight: 600;
      transition: all 0.3s ease;
      border: none;
      cursor: pointer;
    }

    .btn-predict:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
      color: #764ba2;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 768px) {
      .page-header h1 {
        font-size: 1.8rem;
      }

      .records-grid {
        grid-template-columns: 1fr;
      }

      .filter-section {
        flex-direction: column;
      }

      .filter-btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-professional">
    <div class="container-fluid px-4">
      <a class="navbar-brand" href="/">
        <i class="fas fa-apple-alt"></i> Food Classifier
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/"><i class="fas fa-home"></i> Home</a>
          <a class="nav-link" href="/prediction"><i class="fas fa-camera"></i> Predict</a>
          <a class="nav-link" href="/dashboard"><i class="fas fa-chart-bar"></i> Dashboard</a>
          <a class="nav-link active" href="/records"><i class="fas fa-history"></i> Records</a>
        </div>
      </div>
    </div>
  </nav>

  <div class="container-main">
    <!-- Page Header -->
    <div class="page-header">
      <h1><i class="fas fa-history"></i> Prediction Records</h1>
      <p>View and manage all your food freshness predictions</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger" role="alert" style="background: rgba(220, 53, 69, 0.9); border: none; color: white;">
        <i class="fas fa-exclamation-circle"></i> <%= error %>
      </div>
    <% } %>

    <% if (records && records.length > 0) { %>
      <!-- Filter Section -->
      <div class="filter-section">
        <button class="filter-btn active" onclick="filterRecords('all')">
          <i class="fas fa-list"></i> All Records
        </button>
        <button class="filter-btn" onclick="filterRecords('fresh')">
          <i class="fas fa-leaf"></i> Fresh Only
        </button>
        <button class="filter-btn" onclick="filterRecords('rotten')">
          <i class="fas fa-times-circle"></i> Rotten Only
        </button>
      </div>

      <!-- Records Grid -->
      <div class="records-grid" id="recordsGrid">
        <% records.forEach(record => { %>
          <div class="record-card" data-status="<%= record.freshness %>">
            <div class="record-id">#<%= record.id %></div>
            <div class="record-product">
              <i class="fas fa-<%= record.freshness === 'Fresh' ? 'check-circle' : 'times-circle' %>" 
                 style="color: <%= record.freshness === 'Fresh' ? '#28a745' : '#dc3545' %>"></i>
              <%= record.product_name || 'Unknown' %>
            </div>
            <div class="record-class">
              <i class="fas fa-tag"></i> <%= record.predicted_class %>
            </div>
            <div class="record-status <%= record.freshness === 'Fresh' ? 'status-fresh' : 'status-rotten' %>">
              <%= record.freshness === 'Fresh' ? '✓ Fresh' : '✗ Rotten' %>
            </div>
            <div class="record-confidence">
              <strong>Confidence: <%= (record.confidence * 100).toFixed(1) %>%</strong>
              <div class="confidence-bar" style="--width: <%= record.confidence * 100 %>%;">
                <div class="confidence-fill"></div>
              </div>
            </div>
            <div class="record-date">
              <i class="fas fa-calendar"></i> <%= record.created_at %>
            </div>
          </div>
        <% }) %>
      </div>

    <% } else { %>
      <!-- Empty State -->
      <div class="empty-state">
        <div class="empty-state-icon"><i class="fas fa-inbox"></i></div>
        <h3>No Records Found</h3>
        <p>You haven't made any predictions yet. Start by uploading an image!</p>
        <a href="/prediction" class="btn-predict">
          <i class="fas fa-camera"></i> Make Your First Prediction
        </a>
      </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function filterRecords(type) {
      const cards = document.querySelectorAll('.record-card');
      const buttons = document.querySelectorAll('.filter-btn');

      // Update button styles
      buttons.forEach(btn => btn.classList.remove('active'));
      event.target.closest('.filter-btn').classList.add('active');

      // Filter cards
      cards.forEach(card => {
        if (type === 'all') {
          card.style.display = '';
        } else if (type === 'fresh' && card.dataset.status === 'Fresh') {
          card.style.display = '';
        } else if (type === 'rotten' && card.dataset.status === 'Rotten') {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    }
  </script>
</body>
</html>
