<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Predict</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

<style>
body {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  padding-top: 100px;
  color: white;
}

.navbar-professional {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 1000;
}

.navbar-professional .nav-link {
  color: white !important;
  margin: 0 10px;
}

.main-box {
  background: rgba(255,255,255,0.95);
  border-radius: 20px;
  padding: 40px;
  color: black;
  text-align: center;
}

/* UPLOAD */
.upload-zone {
  border: 2px dashed #667eea;
  border-radius: 15px;
  padding: 40px;
  cursor: pointer;
  transition: 0.3s;
}

.upload-zone:hover {
  background: #f1f3ff;
}

.image-preview {
  max-width: 250px;
  margin-top: 20px;
  display: none;
  border-radius: 10px;
}

/* RESULT */
.result-box {
  margin-top: 30px;
  display: none;
}

.badge-fresh {
  background: green;
  color: white;
  padding: 8px 15px;
  border-radius: 10px;
}

.badge-rotten {
  background: red;
  color: white;
  padding: 8px 15px;
  border-radius: 10px;
}

.confidence-bar {
  height: 10px;
  background: #ddd;
  border-radius: 10px;
  margin-top: 10px;
}

.confidence-fill {
  height: 10px;
  border-radius: 10px;
  background: linear-gradient(to right, #667eea, #764ba2);
}
</style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-professional">
  <div class="container-fluid px-4">
    <a class="navbar-brand text-white" href="/">🍎 Food AI</a>

    <div class="navbar-nav ms-auto">
      <a class="nav-link" href="/">Home</a>
      <a class="nav-link active" href="/prediction">Predict</a>
      <a class="nav-link" href="/dashboard">Dashboard</a>
      <a class="nav-link" href="/analytics">Analytics</a>
    </div>
  </div>
</nav>

<div class="container">

<h2 class="text-center mb-4 text-white">Upload Food Image</h2>

<div class="main-box">

<form id="form">

<!-- UPLOAD -->
<div class="upload-zone" id="uploadZone">
  <i class="fas fa-cloud-upload-alt fa-3x mb-3" style="color:#667eea;"></i>
  <p>Click to upload or drag & drop</p>
  <small>JPG, PNG (Max 10MB)</small>
</div>

<input type="file" id="fileInput" name="image" hidden>

<img id="preview" class="image-preview">

<div class="mt-3">
  <button class="btn btn-primary" id="predictBtn" style="display:none;">
    <i class="fas fa-magic"></i> Classify Image
  </button>

  <button type="button" class="btn btn-secondary" onclick="clearImage()">
    Clear
  </button>
</div>

</form>

<!-- RESULT -->
<div id="resultBox" class="result-box">

<h4 id="statusText"></h4>

<div class="mt-3">
  <span id="badge"></span>
</div>

<div class="mt-3">
  <h5>Confidence: <span id="confidence"></span></h5>
  <div class="confidence-bar">
    <div id="bar" class="confidence-fill"></div>
  </div>
</div>

</div>

</div>
</div>

<script>
const uploadZone = document.getElementById("uploadZone");
const fileInput = document.getElementById("fileInput");
const preview = document.getElementById("preview");
const predictBtn = document.getElementById("predictBtn");

uploadZone.onclick = () => fileInput.click();

uploadZone.ondragover = (e) => {
  e.preventDefault();
  uploadZone.style.background = "#eef2ff";
};

uploadZone.ondragleave = () => {
  uploadZone.style.background = "";
};

uploadZone.ondrop = (e) => {
  e.preventDefault();
  fileInput.files = e.dataTransfer.files;
  previewImage();
};

fileInput.onchange = previewImage;

function previewImage() {
  const file = fileInput.files[0];
  if (!file) return;

  preview.src = URL.createObjectURL(file);
  preview.style.display = "block";
  predictBtn.style.display = "inline-block";
}

function clearImage() {
  fileInput.value = "";
  preview.style.display = "none";
  predictBtn.style.display = "none";
  document.getElementById("resultBox").style.display = "none";
}

document.getElementById("form").onsubmit = async (e) => {
  e.preventDefault();

  const formData = new FormData();
  formData.append("image", fileInput.files[0]);

  const res = await fetch("/predict", {
    method: "POST",
    body: formData
  });

  const data = await res.json();

  if (!data.success) {
    alert(data.error);
    return;
  }

  const p = data.prediction;
  const percent = Math.round(p.confidence * 100);

  // STATUS
  document.getElementById("statusText").innerText =
    p.freshness === "Fresh" ? "✅ Fresh Food" : "❌ Rotten Food";

  // BADGE
  document.getElementById("badge").innerHTML =
    p.freshness === "Fresh"
      ? '<span class="badge-fresh">Fresh</span>'
      : '<span class="badge-rotten">Rotten</span>';

  // CONFIDENCE
  document.getElementById("confidence").innerText = percent + "%";
  document.getElementById("bar").style.width = percent + "%";

  document.getElementById("resultBox").style.display = "block";
};
</script>

</body>
</html>