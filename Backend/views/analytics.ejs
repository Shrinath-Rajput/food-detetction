<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Analytics</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  padding-top: 80px;
  color: white;
}

/* NAVBAR SAME */
.navbar-professional {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 1000;
}

.navbar-professional .nav-link {
  color: white !important;
  margin: 0 10px;
}

/* CARD */
.card-box {
  background: rgba(255,255,255,0.95);
  border-radius: 15px;
  padding: 25px;
  color: black;
  text-align: center;
}

.chart-box {
  background: white;
  border-radius: 15px;
  padding: 30px;
}
</style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-professional">
  <div class="container-fluid px-4">
    <a class="navbar-brand text-white" href="/">
      <i class="fas fa-apple-alt"></i> Food AI
    </a>

    <div class="navbar-nav ms-auto">
      <a class="nav-link" href="/">Home</a>
      <a class="nav-link" href="/prediction">Predict</a>
      <a class="nav-link" href="/dashboard">Dashboard</a>
      <a class="nav-link active" href="/analytics">Analytics</a>
    </div>
  </div>
</nav>

<div class="container mt-5 text-center">

<h2 class="mb-4">📊 Food Analytics</h2>
<p>Fresh vs Rotten Analysis</p>

<%
let fresh = 0;
let rotten = 0;

data.forEach(d => {
  if(d.freshness === "Fresh") fresh++;
  else rotten++;
});

let total = data.length;
%>

<!-- STATS -->
<div class="row mb-4">
  <div class="col-md-4">
    <div class="card-box">
      <h5>Total</h5>
      <h2><%= total %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card-box">
      <h5>Fresh</h5>
      <h2><%= fresh %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card-box">
      <h5>Rotten</h5>
      <h2><%= rotten %></h2>
    </div>
  </div>
</div>

<!-- CHART -->
<div class="chart-box">
  <canvas id="chart"></canvas>
</div>

<br>
<a href="/" class="btn btn-light">⬅ Back</a>

</div>

<script>
const fresh = <%= fresh %>;
const rotten = <%= rotten %>;

new Chart(document.getElementById("chart"), {
  type: "bar",
  data: {
    labels: ["Fresh", "Rotten"],
    datasets: [{
      label: "Food Count",
      data: [fresh, rotten]
    }]
  }
});
</script>

</body>
</html>